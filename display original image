import cv2
import matplotlib.pyplot as plt

# Load the image
# Assuming 'image_url' from the kernel state refers to an existing image file.
# If this file doesn't exist or is not a valid image, this will cause an error.
image_path = '/content/Screenshot 2026-06-25 104113.png'
img = cv2.imread(image_path)

# Check if the image was loaded successfully
if img is None:
    print(f"Error: Could not load image from {image_path}")
else:
    # OpenCV loads images in BGR format, Matplotlib expects RGB.
    # Convert the color format for correct display.
    img_rgb = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)
    
    # Display the image using Matplotlib
    plt.imshow(img_rgb)
    plt.title('Displayed Image from OpenCV')
    plt.axis('off') # Hide axes ticks and labels
    plt.show()

